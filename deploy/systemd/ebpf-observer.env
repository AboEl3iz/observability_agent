# eBPF Observability Agent Configuration Options
# Used by the /etc/systemd/system/ebpf-observer.service file

EBPF_OBSERVER_OPTS="\
  --cpu-bpf /usr/local/share/ebpf-observer/cpu.o \
  --mem-bpf /usr/local/share/ebpf-observer/memory.o \
  --io-bpf /usr/local/share/ebpf-observer/io.o \
  --net-bpf /usr/local/share/ebpf-observer/network.o \
  --sys-bpf /usr/local/share/ebpf-observer/syscall.o \
  --lineage-bpf /usr/local/share/ebpf-observer/lineage.o \
  --exec-bpf /usr/local/share/ebpf-observer/exec.o \
  --dns-bpf /usr/local/share/ebpf-observer/dns.o \
  --privesc-bpf /usr/local/share/ebpf-observer/privesc.o \
  --escape-bpf /usr/local/share/ebpf-observer/escape.o \
  --containers-only \
  --show-security \
  --rich-mem"
